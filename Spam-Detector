emails = spam_emails + non_spam_emails
labels = ["spam"] * len(spam_emails) + ["non-spam"] * len(non_spam_emails)

def train_model():
    print("Training model...")
    vectorizer = CountVectorizer()
    X = vectorizer.fit_transform(emails)

    model = MultinomialNB()
    model.fit(X, labels)

    print("Model trained!")
    return model, vectorizer


def predict_email(email, model, vectorizer):
    X = vectorizer.transform([email])
    result = model.predict(X)[0]
    probs = model.predict_proba(X)[0]

    spam_prob = probs[list(model.classes_).index("spam")] * 100
    non_spam_prob = probs[list(model.classes_).index("non-spam")] * 100

    return result, spam_prob, non_spam_prob


def main():
    model, vectorizer = train_model()

    while True:
        print("\n1. Check Email\n2. Exit")
        choice = input("Enter choice: ")

        if choice == "1":
            email = input("Enter email:\n> ")
            result, spam_p, non_spam_p = predict_email(email, model, vectorizer)

            print("\nResult:", "SPAM" if result == "spam" else "NOT SPAM")
            print(f"Spam Probability: {spam_p:.1f}%")
            print(f"Normal Probability: {non_spam_p:.1f}%")

        elif choice == "2":
            break

        else:
            print("Invalid choice")


main()
